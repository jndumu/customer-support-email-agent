# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=customer-support
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# Email (IMAP / SMTP — for future integration)
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USE_TLS=true

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=customer-support-email-agent
